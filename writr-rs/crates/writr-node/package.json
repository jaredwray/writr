{
	"name": "writr-node",
	"version": "0.1.0",
	"private": true,
	"description": "Node.js binding for writr-rs, the Rust-native writr markdown engine.",
	"type": "commonjs",
	"main": "index.js",
	"types": "index.d.ts",
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"napi": {
		"binaryName": "writr-node",
		"targets": [
			"x86_64-unknown-linux-gnu",
			"aarch64-unknown-linux-gnu",
			"x86_64-unknown-linux-musl",
			"aarch64-unknown-linux-musl",
			"x86_64-apple-darwin",
			"aarch64-apple-darwin",
			"x86_64-pc-windows-msvc",
			"wasm32-wasip1"
		]
	},
	"devDependencies": {
		"@napi-rs/cli": "^3.7.3",
		"@napi-rs/wasm-runtime": "^1.1.6",
		"emnapi": "1.11.2",
		"playwright-core": "^1.61.1"
	}
}
