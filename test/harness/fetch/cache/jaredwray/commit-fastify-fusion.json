izations_url":"https://api.github.com/users/web-flow/orgs","repos_url":"https://api.github.com/users/web-flow/repos","events_url":"https://api.github.com/users/web-flow/events{/privacy}","received_events_url":"https://api.github.com/users/web-flow/received_events","type":"User","user_view_type":"public","site_admin":false},"parents":[{"sha":"cff83fb0f97011f5b7d22f8d4fec4a996b35127b","url":"https://api.github.com/repos/jaredwray/fastify-fusion/commits/cff83fb0f97011f5b7d22f8d4fec4a996b35127b","html_url":"https://github.com/jaredwray/fastify-fusion/commit/cff83fb0f97011f5b7d22f8d4fec4a996b35127b"},{"sha":"2e757f861b85d41fcea0884a753d6b044a0b3ea1","url":"https://api.github.com/repos/jaredwray/fastify-fusion/commits/2e757f861b85d41fcea0884a753d6b044a0b3ea1","html_url":"https://github.com/jaredwray/fastify-fusion/commit/2e757f861b85d41fcea0884a753d6b044a0b3ea1"}],"stats":{"total":14,"additions":14,"deletions":0},"files":[{"sha":"65b7fdc6493f0566e1eb05582baf8dc104849ff7","filename":"site/docula.config.ts","status":"modified","additions":14,"deletions":0,"changes":14,"blob_url":"https://github.com/jaredwray/fastify-fusion/blob/0465c5534363d0e30332c68fc1f9deac337fbdf3/site%2Fdocula.config.ts","raw_url":"https://github.com/jaredwray/fastify-fusion/raw/0465c5534363d0e30332c68fc1f9deac337fbdf3/site%2Fdocula.config.ts","contents_url":"https://api.github.com/repos/jaredwray/fastify-fusion/contents/site%2Fdocula.config.ts?ref=0465c5534363d0e30332c68fc1f9deac337fbdf3","patch":"@@ -14,3 +14,17 @@ export const options: Partial<DoculaOptions> = {\n \tenableReleaseChangelog: true,\n \tenableLlmsTxt: true,\n };\n+\n+// The docula template already renders the site logo in the header. The project\n+// README.md also opens with a logo image, which `autoReadme` would render a\n+// second time in the home page body — producing a duplicate logo. Strip that\n+// leading logo from the rendered README so only the header logo remains.\n+//\n+// docula prepends a \"# <name>\" heading when the README starts with the logo\n+// instead of a heading, so the logo sits just after an optional leading H1. The\n+// pattern is anchored to the start of the document (no `m` flag) and preserves\n+// that heading via the capture group, so images deeper in the README are never\n+// touched. README.md on disk is left untouched, so the logo still shows on\n+// GitHub and npm.\n+export const onAutoReadme = (content: string): string =>\n+\tcontent.replace(/^(#\\s+[^\\n]*\\r?\\n\\s*)?!\\[[^\\]]*\\]\\([^)]*\\)[ \\t]*\\r?\\n+/, \"$1\");"}]}